# Local knowledge base configuration.
# Copy to env.local and edit local-only values. Do not commit env.local.

NOTES_DIR="notes"
OBSIDIAN_VAULT_DIR=""
SOURCE_DIR="source"
LOCAL_NOTE_STUDIO_PROJECT_DIR="/Users/xxx/Files/Agent/local-note-studio"
KNOWLEDGE_BASE_PROJECT_DIR="/Users/xxx/Files/Agent/knowledge-base"
CODEX_PYTHON_BIN="python3"
DEFAULT_OUTPUT_ROOT="/Users/xxx/Notes"
SAMPLE_OUTPUT_DIR="notes/_samples/source-conversion"
ORGANIZED_OUTPUT_DIR="notes/_organized"
INDEX_DIR="indexes"
AI_PAPER_DRAFT_DIR="_drafts/AI_paper"
AI_PAPER_NOTE_DIR="notes/AI/AI_paper"
AI_PAPER_QUICKREAD_DIR="notes/AI/_quickread/AI_paper"

DEFAULT_LLM_PROVIDER="lmstudio"
