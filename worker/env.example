BILIBILI_WEB_SUBTITLE_LANGS="zh-CN,zh-Hans,zh-Hant,zh-TW,ai-zh,en,ai-en,ja,ai-ja,ko,ai-kr"
BROWSER_TYPE="chrome"

SUMMARY_API_KEY="lm-studio"
