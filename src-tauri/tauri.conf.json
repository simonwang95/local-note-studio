{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Local Note Studio",
  "version": "0.1.0",
  "identifier": "studio.local-note.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Local Note Studio",
        "width": 1180,
        "height": 760,
        "minWidth": 900,
        "minHeight": 620
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "app",
    "icon": []
  }
}
