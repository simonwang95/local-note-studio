{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Local Note Studio",
  "version": "0.1.12",
  "identifier": "studio.local-note",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Local Note Studio",
        "width": 1180,
        "height": 760,
        "minWidth": 900,
        "minHeight": 620
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns"],
    "resources": [
      "../worker/local_note_studio_worker.py",
      "../worker/requirements-managed.lock",
      "../worker/env.example",
      "../worker/scripts/*.py",
      "../worker/scripts/*.swift",
      "../worker/scripts/bilibili/*.py",
      "../worker/scripts/bilibili/*.sh",
      "../docs/code_list_20260612.csv"
    ],
    "category": "Productivity",
    "shortDescription": "Local-first note processing studio",
    "longDescription": "Turn local documents, webpages, videos, and papers into Obsidian-compatible Markdown notes.",
    "macOS": {
      "minimumSystemVersion": "12.0"
    }
  }
}
